HOST=0.0.0.0
PORT=1337

# Beim Start fehlende users-permissions für public/authenticated anlegen (idempotent)
INIT_PERMISSIONS=false
# Optional: zusätzliche Actions (kommasepariert), z.B. api::form-instance.form-instance.create
# INIT_PERMISSIONS_EXTRA=
APP_KEYS="toBeModified1,toBeModified2"
API_TOKEN_SALT=tobemodified
ADMIN_JWT_SECRET=tobemodified
TRANSFER_TOKEN_SALT=tobemodified
JWT_SECRET=tobemodified
ENCRYPTION_KEY=tobemodified

# Basis-URL des Frontends fuer Links in System-E-Mails (Passwort-Reset)
CLIENT_URL=http://localhost:3000
