STRAPI_BASE_URL=http://localhost:1337
NEXT_PUBLIC_STRAPI_BASE_URL=http://localhost:1337

NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me

AUTHENTIK_ISSUER=https://auth.example.org/application/o/hzd/
AUTHENTIK_CLIENT_ID=change-me
# Optional: Confidential Client in Authentik (sonst Public Client mit PKCE)
# AUTHENTIK_CLIENT_SECRET=change-me
# AUTHENTIK_TOKEN_ENDPOINT_AUTH_METHOD=client_secret_post
AUTHENTIK_SCOPE=openid email profile offline_access
# Optional: login = Login-Maske erzwingen (sonst SSO ohne Maske wenn Authentik-Session aktiv)
# AUTHENTIK_PROMPT=login
# AUTHENTIK_MAX_AGE=0
AUTHENTIK_LOG_TOKENS=false
# Nach Logout: Redirect-Ziel (muss in Authentik als Logout-Redirect-URI eingetragen sein)
# AUTHENTIK_POST_LOGOUT_REDIRECT_URI=https://example.org/
# Optional, falls Discovery-URLs nicht verwendet werden sollen:
# AUTHENTIK_END_SESSION_URL=https://auth.example.org/application/o/hzd/end-session/
# AUTHENTIK_REVOCATION_URL=https://auth.example.org/application/o/revoke/
