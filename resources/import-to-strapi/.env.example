# Strapi GraphQL API
STRAPI_GRAPHQL_URL=http://localhost:1337/graphql
STRAPI_API_TOKEN=replace-with-strapi-api-token

# Authentik API
AUTHENTIK_BASE_URL=http://localhost:9000
AUTHENTIK_API_TOKEN=replace-with-authentik-api-token

# Shared import connectivity settings
IMPORT_HTTP_TIMEOUT=30
IMPORT_REQUEST_DELAY=0.1

# Optional service-specific overrides
STRAPI_HTTP_TIMEOUT=30
STRAPI_PAGE_SIZE=100
STRAPI_MAX_RETRIES=3
AUTHENTIK_HTTP_TIMEOUT=30
AUTHENTIK_PAGE_SIZE=100

# Legacy keys still supported by the import scripts:
# ENDPOINT is used as a fallback for STRAPI_GRAPHQL_URL.
# TOKEN is used as a fallback for STRAPI_API_TOKEN.
