    },
    "FormInstanceId": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "FormInstanceUid": {
      "type": "uid",
      "targetField": "",
      "required": true
    },
    "StateHistory": {
      "type": "dynamiczone",
      "components": [
        "hzd-form.stage-state",
        "hzd-form.stage-signature"
      ]
    }
  }
