REDMINE_VERSION=6
REDMINE_PORT=8080

REDMINE_DB_HOST=db.example.com
REDMINE_DB_PORT=3306
REDMINE_DB_NAME=redmine
REDMINE_DB_USER=redmine
REDMINE_DB_PASSWORD=supersecret

REDMINE_SECRET_KEY_BASE=generate_a_long_random_key_here

REDMINE_SMTP_ENABLED=true
REDMINE_SMTP_ADDRESS=smtp.example.com
REDMINE_SMTP_PORT=587
REDMINE_SMTP_DOMAIN=example.com
REDMINE_SMTP_USER=redmine@example.com
REDMINE_SMTP_PASSWORD=smtppass
REDMINE_SMTP_AUTH=login
REDMINE_SMTP_STARTTLS=true