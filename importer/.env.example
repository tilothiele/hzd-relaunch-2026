# HZD Importer – Beispiel-Konfiguration
# Kopieren: cp .env.example .env
# Variablen laden: set -a && source .env && set +a
# Quarkus starten: ./gradlew quarkusDev
# Produktion:     ./gradlew quarkusRun -Dquarkus.profile=prod

# HTTP
QUARKUS_HTTP_PORT=8081

# Quarkus-Profil (dev | prod)
QUARKUS_PROFILE=dev

# CSV-Eingabedateien (absolute oder relative Pfade)
IMPORTER_CSV_MEMBERS_PATH=members.csv
IMPORTER_CSV_DOGS_PATH=dogs.csv

# Scheduler (in prod standardmäßig aktiv, siehe application-prod.properties)
IMPORTER_SCHEDULER_ENABLED=false
# Täglich um 02:00 Uhr (Quartz-Syntax)
IMPORTER_SCHEDULER_CRON=0 0 2 * * ?

# Strapi REST API
IMPORTER_STRAPI_BASE_URL=http://localhost:1337/api
IMPORTER_STRAPI_API_TOKEN=replace-with-strapi-api-token
IMPORTER_STRAPI_HTTP_TIMEOUT=30s
IMPORTER_STRAPI_PAGE_SIZE=100
IMPORTER_STRAPI_MAX_RETRIES=3
IMPORTER_STRAPI_REQUEST_DELAY=100ms
IMPORTER_STRAPI_DEFAULT_PASSWORD=Import-%d-ChangeMe!

# Authentik REST API
IMPORTER_AUTHENTIK_BASE_URL=https://auth.hovawarte.com
# Option A: API-Token (empfohlen für Automation)
IMPORTER_AUTHENTIK_API_TOKEN=replace-with-authentik-api-token
# Option B: Username/Passwort über Authentik-Flow-Executor (Session-Auth)
# Login identifier exactly as in the Authentik web form (often email, not internal username)
# IMPORTER_AUTHENTIK_USERNAME=user@example.org
# IMPORTER_AUTHENTIK_PASSWORD=replace-with-password
# IMPORTER_AUTHENTIK_AUTH_FLOW=default-authentication-flow
# Kommagetrennte Authentik-Gruppen für User-Upserts (ersetzt frühere Hardcodierung in Member)
IMPORTER_AUTHENTIK_DEFAULT_GROUPS=website-users
IMPORTER_AUTHENTIK_HTTP_TIMEOUT=30s
IMPORTER_AUTHENTIK_PAGE_SIZE=100

# Retry bei transienten Strapi-Fehlern
IMPORTER_RETRY_INITIAL_DELAY=1s
IMPORTER_RETRY_MAX_DELAY=30s

# Job-Datenbank (prod – PostgreSQL)
QUARKUS_DATASOURCE_DB_KIND=postgresql
QUARKUS_DATASOURCE_USERNAME=importer
QUARKUS_DATASOURCE_PASSWORD=replace-with-db-password
QUARKUS_DATASOURCE_JDBC_URL=jdbc:postgresql://localhost:5432/importer

# Kompatibilität mit den Python-Import-Skripten (optional, nur Dokumentation):
# STRAPI_GRAPHQL_URL  → IMPORTER_STRAPI_GRAPHQL_URL
# STRAPI_API_TOKEN    → IMPORTER_STRAPI_API_TOKEN
# AUTHENTIK_BASE_URL  → IMPORTER_AUTHENTIK_BASE_URL
# AUTHENTIK_API_TOKEN → IMPORTER_AUTHENTIK_API_TOKEN
