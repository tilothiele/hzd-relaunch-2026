HOST=0.0.0.0
PORT=1337

# Beim Start fehlende users-permissions für public/authenticated anlegen (idempotent)
INIT_PERMISSIONS=false
# Optional: zusätzliche Actions (kommasepariert), z.B. api::form-instance.form-instance.create
# INIT_PERMISSIONS_EXTRA=
APP_KEYS="toBeModified1,toBeModified2"
API_TOKEN_SALT=tobemodified
ADMIN_JWT_SECRET=tobemodified
TRANSFER_TOKEN_SALT=tobemodified
JWT_SECRET=tobemodified
ENCRYPTION_KEY=tobemodified

# Basis-URL des Frontends fuer Links in System-E-Mails (Passwort-Reset)
CLIENT_URL=http://localhost:3000

# Authentik OIDC/JWT-Verifikation fuer Frontend-Bearer-Tokens
AUTHENTIK_ISSUER=https://auth.example.org/application/o/website-frontend
# Gleiche Client-ID wie im Frontend (Fallback fuer JWT-Audience-Pruefung)
AUTHENTIK_CLIENT_ID=frontend-client-id
# Optional: Confidential Client – aktiviert Token-Introspection als Fallback
# AUTHENTIK_CLIENT_SECRET=change-me
# Optional, ueberschreibt AUTHENTIK_CLIENT_ID als erwartete Audience
# AUTHENTIK_AUDIENCE=frontend-client-id
AUTHENTIK_USERNAME_CLAIM=preferred_username
AUTHENTIK_EMAIL_CLAIM=email
# Optional, falls Discovery-URLs nicht verwendet werden sollen
# AUTHENTIK_JWKS_URI=https://auth.example.org/application/o/website-frontend/jwks/
# AUTHENTIK_INTROSPECTION_URL=https://auth.example.org/application/o/introspect/
